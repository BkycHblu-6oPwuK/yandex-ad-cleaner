{
    "manifest_version": 3,
    "name": "Yandex Ad Cleaner",
    "version": "0.0.1",
    "description": "Убирает рекламные блоки на сайтах Яндекса и Дзена",
    "content_scripts": [
        {
            "matches": [
                "*://*.yandex.ru/*",
                "*://*.dzen.ru/*",
                "*://*.kinopoisk.ru/*",
                "*://*.ya.ru/*",
                "*://*.auto.ru/*",
                "*://*.yandex.cloud/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },

    "browser_specific_settings": {
        "gecko": {
            "id": "ad-cleaner@local",
            "strict_min_version": "109.0"
        }
    }
}